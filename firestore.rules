rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email in ['pauladamu600@gmail.com'];
    }

    function isOwner(uidField) {
      return isSignedIn() && request.auth.uid == uidField;
    }

    function canUpdateStudentProfile() {
      return isOwner(resource.data.uid)
        && (resource.data.lastUpdated == null
          || request.time.toMillis() > resource.data.lastUpdated.toMillis() + 604800000)
        && request.resource.data.lastUpdated == request.time;
    }

    // Any signed-in user (not the student themselves) can add a review
    function canAddReview() {
      return isSignedIn()
        && request.auth.uid != resource.data.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reviews', 'rating']);
    }

    match /students/{studentId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update: if canUpdateStudentProfile() || canAddReview() || isAdmin();
      allow delete: if isOwner(resource.data.uid);
    }

    match /users/{userId} {
      allow read: if isAdmin() || request.auth.uid == userId;
      allow create: if isSignedIn() && request.auth.uid == userId && request.resource.data.email == request.auth.token.email;
      allow update, delete: if request.auth.uid == userId;
    }

    match /gigs/{gigId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.postedBy == request.auth.uid;
      // Owner can update anything; any auth user can increment applicants count only
      allow update: if isSignedIn() && (
        resource.data.postedBy == request.auth.uid ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['applicants'])
      );
      allow delete: if isSignedIn() && resource.data.postedBy == request.auth.uid;
    }

    match /applications/{appId} {
      allow create: if isSignedIn() && request.resource.data.studentId == request.auth.uid;
      allow read: if isAdmin() || request.auth.uid == resource.data.studentId || request.auth.uid == resource.data.gigPosterId;
      allow update, delete: if request.auth.uid == resource.data.studentId || request.auth.uid == resource.data.gigPosterId;
    }

    match /pendingVerifications/{verificationId} {
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow read, update, delete: if isAdmin() || request.auth.uid == resource.data.uid;
    }

    match /adminUsers/{adminId} {
      allow read, write: if isAdmin();
    }

    match /flaggedContent/{flagId} {
      allow read, write: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /notifications/{notifId} {
      allow read, update: if isSignedIn() && request.auth.uid == resource.data.userId;
      allow create: if isSignedIn();
      allow delete: if isSignedIn() && request.auth.uid == resource.data.userId;
    }

    match /referrals/{referralId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.referrerUid ||
        request.auth.uid == resource.data.refereeUid ||
        isAdmin()
      );
      allow create: if isSignedIn() && request.resource.data.refereeUid == request.auth.uid;
      allow update, delete: if isAdmin();
    }
  }
}
