rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Gigs — public read, auth required to write
    match /gigs/{gig} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Students — public read, auth required to write
    match /students/{student} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Settings (spotlight) — public read, auth required to write
    match /settings/{setting} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Admin collections — authenticated users only
    match /adminUsers/{userId} {
      allow read, write: if request.auth != null;
    }

    match /pendingVerifications/{id} {
      allow read, write: if request.auth != null;
    }

    match /flaggedContent/{id} {
      allow read, write: if request.auth != null;
    }

    // User profiles — public read, owner write
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
